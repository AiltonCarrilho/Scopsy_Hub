# ==========================================
# SCOPSY - .gitignore
# ==========================================
# Previne envio de dados sensíveis para GitHub

# ==========================================
# SECRETS (NUNCA COMMITAR!)
# ==========================================
.env
.env.local
.env.production
.env.*.local
start.ps1
config/*.ps1
*.secret.*
*.env

# ==========================================
# NODE
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json  # Opcional (alguns preferem versionar)

# ==========================================
# LOGS
# ==========================================
logs/
*.log
log/
scopsy.log

# ==========================================
# SISTEMA OPERACIONAL
# ==========================================
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ==========================================
# IDEs E EDITORES
# ==========================================
# VSCode
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# ==========================================
# TEMPORÁRIOS
# ==========================================
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ==========================================
# BUILD/DIST (se adicionar build step futuro)
# ==========================================
dist/
build/
out/
.cache/

# ==========================================
# TESTES
# ==========================================
coverage/
.nyc_output/
*.lcov

# ==========================================
# OUTROS
# ==========================================
# Arquivos de debug
debug/
*.debug

# Arquivos de backup do editor
*.orig

# Certificados SSL (se tiver localmente)
*.pem
*.key
*.crt

# ==========================================
# SCOPSY ESPECÍFICO
# ==========================================
# Dados de usuários (se salvar localmente)
data/users/
uploads/temp/

# Scripts de migração com dados sensíveis
migrations/*_seed_data.sql
test-key.js
SECURITY_ALERT.md
.vercel
.env*.local

# ==========================================
# SISTEMA DE REVISÃO - Dados e Exports
# ==========================================
# Backups de casos
backup-*.json
backup-cases-*.json

# Análises e relatórios gerados
analise-*.json
relatorio-*.json
review-results.json
review-report.html
tracking-*.csv

# Exports de casos
casos-expert-*.json
casos-expert-*.csv
casos-expert-*.txt
casos-para-*.csv

# Scripts temporários (one-off)
check-*.js
fix-*.js
test-*.js
diagnose-*.js
investigate-*.js

# SQL scripts de deleção específica (não reutilizáveis)
sql-delete-*.sql
sql-mark-*.sql

# Windows NUL file
NUL

# ==========================================
# ARQUIVOS DE MÍDIA PESADOS (Backups)
# ==========================================
# Backups de vídeos originais (não comprimidos)
*-ORIGINAL.mp4
*-original.mp4
*-backup.mp4

# Dependencies (AIOS)
node_modules

# AIOS Local (AIOS)
.aios-core/local/
.claude/settings.local.json
.aios/install-log.txt
