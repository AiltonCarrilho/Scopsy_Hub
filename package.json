{
  "name": "scopsy-backend",
  "version": "1.0.0",
  "description": "Backend do Scopsy - Plataforma SaaS de treinamento TCC para psicólogos",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "security:scan": "npm run security:scan:claude && npm run security:scan:code && npm run security:scan:deps",
    "security:scan:claude": "npx ecc-agentshield scan --min-severity medium",
    "security:scan:code": "eslint src/**/*.js --format json > .reports/eslint-report.json 2>&1 || true",
    "security:scan:deps": "npm audit --json > .reports/audit-report.json 2>&1 || true",
    "security:scan:fix": "eslint src/**/*.js --fix && npm audit fix",
    "security:report": "npm run security:scan && echo '✅ Security reports generated in .reports/'",
    "prepare": "husky install"
  },
  "keywords": [
    "tcc",
    "psicologia",
    "treinamento",
    "openai",
    "assistants"
  ],
  "author": "Ailton",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@supabase/supabase-js": "^2.81.1",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "fs-extra": "^11.3.3",
    "helmet": "^7.1.0",
    "inquirer": "^13.2.5",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "openai": "^4.104.0",
    "resend": "^6.6.0",
    "socket.io": "^4.6.1",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "ecc-agentshield": "^1.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^1.7.1",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
