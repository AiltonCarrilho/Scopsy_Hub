# ==========================================
# SCOPSY Backend - Environment Variables
# ==========================================
# Copie para .env.local e preencha valores reais
# NÃO commite .env.local (tem secrets!)

# ==========================================
# NODE ENVIRONMENT
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# FRONTEND (CORS)
# ==========================================
# Desenvolvimento: Live Server
FRONTEND_URL=http://127.0.0.1:5500
# Produção (descomentar depois):
# FRONTEND_URL=https://scopsy.com.br

# ==========================================
# SUPABASE (Database Principal)
# ==========================================
SUPABASE_URL=https://klbguizaixitv.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# ⚠️ IMPORTANTE: Validar se URL é klbguizaixitv ou klbguzaixitv
# Execute: node scripts/test-supabase-url.js

# ==========================================
# OPENAI API
# ==========================================
OPENAI_API_KEY=sk-proj-your-key-here

# Assistants IDs (obter do OpenAI Platform)
# MVP v1.0: 3 visíveis + 1 interno
ORCHESTRATOR_ID=asst_n4KRyVMnbDGE0bQrJAyJspYw
CASE_ID=asst_gF2t61jT43Kgwx6mb6pDEty3
DIAGNOSTIC_ID=asst_UqKPTw0ui3JvOt8NuahMLkAc
JOURNEY_ID=asst_ydS6z2mQO82DtdBN4B1HSHP3

# Futuro v2.0: 2 adicionais
# SUPERVISION_ID=asst_xxx
# DOCUMENTS_ID=asst_yyy

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Gerar com: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-256-bits
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/scopsy.log

# ==========================================
# TOKEN LIMITS (Controle de custos OpenAI)
# ==========================================
TOKEN_LIMIT_FREE=1000
TOKEN_LIMIT_BASIC=5000
TOKEN_LIMIT_PRO=20000
TOKEN_LIMIT_PREMIUM=100000

# ==========================================
# STRIPE (Pagamentos) - FASE 2
# ==========================================
# Descomentar quando implementar monetização
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# STRIPE_PRICE_BASIC=price_xxx
# STRIPE_PRICE_PRO=price_yyy
# STRIPE_PRICE_PREMIUM=price_zzz

# ==========================================
# BOOST.SPACE (Automações) - FASE 2
# ==========================================
# Descomentar quando adicionar badges/emails
# BOOST_SPACE_API_KEY=your-boost-space-api-key
# BOOST_SPACE_SPACE_ID=your-space-id
# BOOST_SPACE_API_URL=https://api.boost.space/v2