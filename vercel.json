{
    "buildCommand": "echo 'No build required - static site'",
    "devCommand": null,
    "installCommand": "echo 'No dependencies to install'",
    "framework": null,
    "outputDirectory": "frontend",
    "cleanUrls": true,
    "headers": [
        {
            "source": "/js/config.js",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/js/(.*)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/javascript; charset=utf-8"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600, must-revalidate"
                }
            ]
        },
        {
            "source": "/css/(.*)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/css; charset=utf-8"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600, must-revalidate"
                }
            ]
        },
        {
            "source": "/favicon.(png|ico)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "image/png"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400"
                }
            ]
        },
        {
            "source": "/(.*).html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        }
    ],
    "redirects": [
        {
            "source": "/lab/:path*",
            "destination": "/dashboard",
            "permanent": true
        },
        {
            "source": "/lab",
            "destination": "/dashboard",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://scopsy-hub.onrender.com/api/:path*"
        },
        {
            "source": "/",
            "destination": "/index.html"
        }
    ]
}
