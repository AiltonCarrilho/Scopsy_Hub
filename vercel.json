{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://scopsy-hub.onrender.com/api/:path*"
        },
        {
            "source": "/",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/:path*",
            "destination": "/frontend/:path*"
        }
    ]
}